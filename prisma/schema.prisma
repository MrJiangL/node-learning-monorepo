generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model UserSession {
  id               String    @id
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Project {
  id          String   @id
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Project 必须属于一个 User。
  //
  // 这里的 userId 是数据库里的外键列，真正保存“这个项目属于哪个用户”。
  // @relation(fields: [userId], references: [id]) 的意思是：
  // - 使用当前 Project 表里的 userId 字段
  // - 去关联 User 表里的 id 字段
  //
  // 注意不要写成 fields: [id]。
  // 如果写成 fields: [id]，就会变成“Project 自己的 id 必须等于 User 的 id”，
  // 这会让 userId 只是一个普通字段，失去真正的外键关系。
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 一个 Project 下面可以有多个 Todo。
  // 这是 Prisma 的反向关系字段，不会在 Project 表里额外生成一列。
  todos Todo[]

  activityLogs ActivityLog[]

  @@index([userId])
}

model User {
  id           String   @id
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plans    Plan[]
  projects Project[]
  sessions UserSession[]

  activityLogs ActivityLog[]
}

model Plan {
  id          String   @id
  title       String
  description String?
  status      String
  difficulty  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model Todo {
  id          String    @id
  title       String
  description String?
  completed   Boolean   @default(false)
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Todo 必须属于一个 Project。
  //
  // 这里先不直接保存 userId，是因为 Todo 的归属可以通过 Project 找到：
  // Todo -> Project -> User
  //
  // 后面做权限判断时，可以先查 Todo 所属的 Project，
  // 再判断 project.userId 是否等于当前登录用户 id。
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Job {
  id             String   @id
  type           String
  idempotencyKey String?  @unique
  payload        Json
  status         String
  attempts       Int      @default(0)
  maxAttempts    Int      @default(3)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  logs JobLog[]

  @@index([status, createdAt])
  @@index([type])
}

model JobLog {
  id        String   @id
  message   String
  createdAt DateTime @default(now())

  jobId String
  job   Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model ActivityLog {
  id        String   @id
  action    String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  projectSnapshotId   String
  projectSnapshotName String?

  @@index([userId, createdAt])
  @@index([projectId, createdAt])
  @@index([action])
  @@index([projectSnapshotId, createdAt])
  // Activity Log 列表查询的核心条件是：
  // - userId：当前用户只能看自己的日志，这是权限边界
  // - projectSnapshotId：Project 删除后也能通过快照 id 查历史日志
  // - createdAt：列表按创建时间倒序展示，也支持时间范围过滤
  //
  // 这个复合索引服务的是 findAll 里的常见查询：
  // where userId + projectSnapshotId + createdAt，再 orderBy createdAt desc。
  @@index([userId, projectSnapshotId, createdAt])
  // 这个索引用来实验带 action 的 Activity Log 查询。
  // 当前查询形状是：
  // where userId + projectSnapshotId + action，再 orderBy createdAt desc。
  //
  // 前三个字段都是等值过滤，createdAt 用来支持按时间倒序读取列表。
  // 注意：它是实验索引，不代表一定要长期保留；是否保留要看 EXPLAIN 和真实业务频率。
  @@index([userId, projectSnapshotId, action, createdAt])
}
